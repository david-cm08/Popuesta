<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Propuesta 💖</title>

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: sans-serif
    }

    body {
      height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
      background: linear-gradient(135deg, #ff9ac8, #ffb6e0, #ffd0ef);
      overflow: hidden;
      text-align: center;
      color: #fff;
    }

    h1 {
      font-size: clamp(40px, 8vw, 90px);
      text-shadow: 0 0 10px #fff
    }

    .botones {
      margin-top: 40px;
      display: flex;
      gap: 60px
    }

    button {
      padding: 18px 45px;
      border: none;
      border-radius: 40px;
      background: #ff4fa3;
      color: #fff;
      font-size: 22px;
      cursor: pointer;
      box-shadow: 0 8px 20px rgba(0, 0, 0, .2);
      transition: .2s;
    }

    button:hover {
      transform: scale(1.05)
    }

    #mensaje {
      display: none;
      position: fixed;
      top: 45%;
      left: 50%;
      transform: translate(-50%, -50%);
      font-size: 80px;
      text-shadow: 0 0 20px #fff;
    }

    #siguiente {
      display: none;
      position: fixed;
      top: 65%;
      left: 50%;
      transform: translate(-50%, -50%);
      font-size: 24px;
      padding: 15px 40px;
    }

    /* MENSAJE FINAL */
    #mensajeFinal {
      display: none;
      position: fixed;
      top: 40%;
      left: 50%;
      transform: translate(-50%, -50%);
      font-size: 60px;
      font-weight: bold;
      color: white;
      text-shadow: 0 0 20px #ff69b4;
      z-index: 1000;
    }

    /* CORAZONES INICIALES */
    .corazon {
      position: fixed;
      animation: subir 5s linear forwards;
    }

    @keyframes subir {
      from {
        transform: translateY(0);
        opacity: 1
      }

      to {
        transform: translateY(-90vh);
        opacity: 0
      }
    }

    /* LLUVIA */
    .lluvia {
      position: fixed;
      top: -50px;
      font-size: 30px;
      animation: caer linear forwards;
    }

    @keyframes caer {
      0% {
        transform: translateY(-50px);
        opacity: 1;
      }

      100% {
        transform: translateY(110vh);
        opacity: 0;
      }
    }
  </style>
</head>

<body>

  <div>
    <h1 id="titulo">¿Quieres ser mi novia? 💖</h1>

    <div class="botones">
      <button id="si">Sí 💘</button>
      <button id="no">No 💔</button>
    </div>
  </div>

  <div id="mensaje">¡Sabía que dirías que sí! 💞</div>

  <button id="siguiente">Siguiente ➜</button>

  <div id="mensajeFinal"></div>

  <script>
    const si = document.getElementById("si")
    const no = document.getElementById("no")
    const titulo = document.getElementById("titulo")
    const msg = document.getElementById("mensaje")
    const siguiente = document.getElementById("siguiente")
    const mensajeFinal = document.getElementById("mensajeFinal")
    const texto = "¿Quieres vivir esta historia conmigo? ❤️"
    /* BOTON NO QUE SE MUEVE */
    function moverNo() {
      const x = Math.random() * (innerWidth - 120)
      const y = Math.random() * (innerHeight - 60)
      no.style.position = "fixed"
      no.style.left = x + "px"
      no.style.top = y + "px"
    }
    no.onmouseenter = moverNo
    /* BOTON SI */
    si.onclick = () => {
      titulo.style.display = "none"
      document.querySelector(".botones").style.display = "none"
      msg.style.display = "block"
      corazones()
      setTimeout(() => {
        siguiente.style.display = "block"
      }, 1500)
    }
    /* BOTON SIGUIENTE */
    siguiente.onclick = () => {
      msg.style.display = "none"
      siguiente.style.display = "none"
      mensajeFinal.style.display = "block"
      escribirMensaje()
    }
    /* EFECTO ESCRIBIR */
    function escribirMensaje() {
      let i = 0
      const intervalo = setInterval(() => {
        mensajeFinal.textContent += texto[i]
        i++
        if (i >= texto.length) {
          clearInterval(intervalo)
          lluviaAmor()
        }
      }, 80)
    }
    /* CORAZONES INICIALES */
    function corazones() {
      for (let i = 0; i < 20; i++) {
        const c = document.createElement("div")
        c.className = "corazon"
        c.innerHTML = "💖"
        c.style.left = Math.random() * innerWidth + "px"
        c.style.top = innerHeight + "px"
        c.style.fontSize = 20 + Math.random() * 30 + "px"
        document.body.appendChild(c)
        setTimeout(() => c.remove(), 5000)
      }
    }
    /* LLUVIA DE CORAZONES Y ROSAS */
    function lluviaAmor() {
      setInterval(() => {
        const elemento = document.createElement("div")
        elemento.className = "lluvia"
        const cosas = ["❤️", "🌹"]
        elemento.innerHTML = cosas[Math.floor(Math.random() * cosas.length)]
        elemento.style.left = Math.random() * innerWidth + "px"
        elemento.style.animationDuration = 3 + Math.random() * 2 + "s"
        document.body.appendChild(elemento)
        setTimeout(() => elemento.remove(), 5000)
      }, 150)
    }
  </script>

</body>

</html>
